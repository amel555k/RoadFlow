<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RoadFlow"
             x:Class="RoadFlow.MainPage"
             Title="MainPage"
             NavigationPage.HasNavigationBar="False">
    <Grid BackgroundColor="White">
        <BoxView x:Name="Overlay"
                 BackgroundColor="Black"
                 Opacity="0"
                 IsVisible="False"
                 InputTransparent="True"
                 ZIndex="1"/>
        <Grid x:Name="ListViewContainer"
              IsVisible="True"
              ZIndex="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Frame Grid.Row="0"
                    BackgroundColor="#212143"
                    Padding="10"
                    CornerRadius="0"
                    HasShadow="False"
                    >
                <VerticalStackLayout Spacing="2">
                    <Grid>
                        <Button x:Name="BtnBurgerMenu"
                                Text="☰"
                                FontSize="24"
                                Clicked="OnBurgerMenuClicked"
                                BackgroundColor="Transparent"
                                TextColor="white"
                                HeightRequest="40"
                                WidthRequest="40"
                                Padding="0"
                                HorizontalOptions="Start"
                                VerticalOptions="Center"/>

                        <Label x:Name="LblCurrentDate"
                                TextColor="White"
                                FontSize="18"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"/>
                                
                        <ImageButton x:Name="BtnRefresh"
                                Clicked="OnRefreshClicked"
                                BackgroundColor="transparent"
                                Source="refresh.png"
                                HeightRequest="20"
                                WidthRequest="20"
                                Padding="2"
                                CornerRadius="20"
                                HorizontalOptions="End"
                                VerticalOptions="Center"/>
                    </Grid>
                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="#3498DB"
                                       HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>

            <AbsoluteLayout Grid.Row="1">

                <Grid AbsoluteLayout.LayoutFlags="All"
                      AbsoluteLayout.LayoutBounds="0,0,1,1"
                      RowDefinitions="Auto,*"
                      Padding="15"
                      BackgroundColor="#EAF4FF">

                    <Frame Grid.Row="0"
                           Padding="10,0"
                           HorizontalOptions="End"
                           Margin="0,0,0,5"
                           BackgroundColor="#4F6F91"
                           WidthRequest="220"
                           CornerRadius="15"
                           HasShadow="False"
                           BorderColor="Transparent">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenPickerClicked"/>
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="*, Auto" HeightRequest="40">
                            <Label x:Name="LblSelectedCanton"
                                   Text="Srednjobosanski kanton"
                                   TextColor="White"
                                   FontSize="14"
                                   VerticalTextAlignment="Center"
                                   HorizontalOptions="Start"/>
                            <Label x:Name="LblPickerArrow"
                                   Grid.Column="1"
                                   Text="▼"
                                   TextColor="White"
                                   FontSize="12"
                                   VerticalTextAlignment="Center"
                                   Margin="5,0,0,0"/>
                        </Grid>
                    </Frame>

                    <Label x:Name="LblNemaData"
                            Grid.Row="1" 
                            Text="Nema dostupnih podataka"
                            FontSize="16"
                            TextColor="Gray"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" 
                            IsVisible="False"
                            ZIndex="1"/>

                    <CollectionView x:Name="RadarListContainer"
                                    Grid.Row="1"
                                    Margin="0,5,0,0"
                                    ItemTemplate="{x:Static local:MainPage.RadarFlatItemTemplate}"/>

                </Grid>

                <BoxView x:Name="DropdownDismissOverlay"
                         AbsoluteLayout.LayoutFlags="All"
                         AbsoluteLayout.LayoutBounds="0,0,1,1"
                         BackgroundColor="Transparent"
                         IsVisible="False"
                         InputTransparent="False"
                         ZIndex="5">
                    <BoxView.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDropdownDismissOverlayTapped"/>
                    </BoxView.GestureRecognizers>
                </BoxView>

                <Frame x:Name="PickerDropdown"
                       AbsoluteLayout.LayoutFlags="None"
                       AbsoluteLayout.LayoutBounds="9999,48,220,420"
                       IsVisible="False"
                       BackgroundColor="#4F6F91"
                       CornerRadius="10"
                       Padding="0"
                       HasShadow="True"
                       BorderColor="Transparent"
                       ZIndex="20">
                    <CollectionView x:Name="CantonCollectionView"
                                    SelectionMode="Single"
                                    SelectionChanged="OnCantonSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="15,10"
                                    BackgroundColor="{Binding BackgroundColor}">
                                    <Label Text="{Binding Label}"
                                        TextColor="{Binding TextColor}"
                                        FontSize="14"
                                        HorizontalOptions="Start"
                                        VerticalOptions="Center"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

            </AbsoluteLayout>
        </Grid>

        <Grid x:Name="MapViewContainer" IsVisible="False" ZIndex="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Frame Grid.Row="0" BackgroundColor="#212143" CornerRadius="0" Padding="10" HasShadow="True">
                <Grid>
                    <Button x:Name="BtnBurgerMenuMap" Text="☰" FontSize="24" Clicked="OnBurgerMenuClicked" BackgroundColor="Transparent" TextColor="White" HeightRequest="40" WidthRequest="40" HorizontalOptions="Start" VerticalOptions="Center"/>
                    <Label Text="Mapa" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
                </Grid>
            </Frame>
            <WebView x:Name="MapView" Grid.Row="1"/>
        </Grid>

        <Grid x:Name="HistoryViewContainer" IsVisible="False" ZIndex="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Frame Grid.Row="0" BackgroundColor="#212143" CornerRadius="0" Padding="10" HasShadow="True">
                <Grid>
                    <Button x:Name="BtnBurgerMenuHistory" Text="☰" FontSize="24" Clicked="OnBurgerMenuClicked" BackgroundColor="Transparent" TextColor="White" HeightRequest="40" WidthRequest="40" HorizontalOptions="Start" VerticalOptions="Center" IsVisible="True"/>
                    <ImageButton x:Name="BtnBackToCalendar" Source="back.png" Clicked="OnBackToCalendarClicked" BackgroundColor="Transparent" HeightRequest="30" WidthRequest="30" Padding="5" HorizontalOptions="Start" VerticalOptions="Center" IsVisible="False"/>
                    <Label x:Name="LblHistoryTitle" Text="Historija Radara" FontSize="20" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" HorizontalOptions="Center"/>
                </Grid>
            </Frame>

            <Grid Grid.Row="1">

                <ScrollView x:Name="HistoryScrollView">
                    <VerticalStackLayout Padding="10" Spacing="10">
                        <Frame x:Name="CalendarFrame" BackgroundColor="White" Padding="15" CornerRadius="10" HasShadow="True" IsVisible="True">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="40,*,40">
                                    <Button Text="◀" Clicked="OnPrevMonthClicked" BackgroundColor="Transparent" TextColor="#212143" FontSize="18"/>
                                    <Label x:Name="LblCalendarMonth" Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" FontSize="18" FontAttributes="Bold" TextColor="#212143"/>
                                    <Button Text="▶" Grid.Column="2" Clicked="OnNextMonthClicked" BackgroundColor="Transparent" TextColor="#212143" FontSize="18"/>
                                </Grid>
                                <Grid x:Name="CalendarGrid" ColumnSpacing="5" RowSpacing="5"/>
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </ScrollView>

                <AbsoluteLayout x:Name="HistoryDataContainer" IsVisible="False">

                    <Grid AbsoluteLayout.LayoutFlags="All"
                          AbsoluteLayout.LayoutBounds="0,0,1,1"
                          RowDefinitions="Auto,*"
                          Padding="15"
                          BackgroundColor="#EAF4FF">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                          

                            <Frame Grid.Column="1"
                                   Padding="10,0"
                                   HorizontalOptions="End"
                                   BackgroundColor="#4F6F91"
                                   WidthRequest="220"
                                   CornerRadius="15"
                                   HasShadow="False"
                                   BorderColor="Transparent">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnHistoryOpenPickerClicked"/>
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="*, Auto" HeightRequest="40">
                                    <Label x:Name="LblHistorySelectedCanton"
                                           Text="Srednjobosanski kanton"
                                           TextColor="White"
                                           FontSize="14"
                                           VerticalTextAlignment="Center"
                                           HorizontalOptions="Start"/>
                                    <Label x:Name="LblHistoryPickerArrow"
                                           Grid.Column="1"
                                           Text="▼"
                                           TextColor="White"
                                           FontSize="12"
                                           VerticalTextAlignment="Center"
                                           Margin="5,0,0,0"/>
                                </Grid>
                            </Frame>
                        </Grid>

                        <ActivityIndicator x:Name="HistoryLoadingIndicator"
                                           Grid.Row="1"
                                           IsRunning="False"
                                           IsVisible="False"
                                           Color="#3498DB"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                        <Label x:Name="LblHistoryNemaData"
                               Grid.Row="1"
                               Text="Nema dostupnih podataka"
                               FontSize="16"
                               TextColor="Gray"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               IsVisible="False"/>

                        <CollectionView x:Name="HistoryRadarListContainer"
                                        Grid.Row="1"
                                        Margin="0,5,0,0"
                                        IsVisible="True"
                                        ItemTemplate="{x:Static local:MainPage.RadarFlatItemTemplate}"/>

                    </Grid>

                    <BoxView x:Name="HistoryDropdownDismissOverlay"
                             AbsoluteLayout.LayoutFlags="All"
                             AbsoluteLayout.LayoutBounds="0,0,1,1"
                             BackgroundColor="Transparent"
                             IsVisible="False"
                             InputTransparent="False"
                             ZIndex="5">
                        <BoxView.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHistoryDropdownDismissOverlayTapped"/>
                        </BoxView.GestureRecognizers>
                    </BoxView>

                    <Frame x:Name="HistoryPickerDropdown"
                           AbsoluteLayout.LayoutFlags="None"
                           AbsoluteLayout.LayoutBounds="9999,48,220,420"
                           IsVisible="False"
                           BackgroundColor="#4F6F91"
                           CornerRadius="10"
                           Padding="0"
                           HasShadow="True"
                           BorderColor="Transparent"
                           ZIndex="20">
                        <CollectionView x:Name="HistoryCantonCollectionView"
                                        SelectionMode="Single"
                                        SelectionChanged="OnHistoryCantonSelected">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="15,10"
                                          BackgroundColor="{Binding BackgroundColor}">
                                        <Label Text="{Binding Label}"
                                               TextColor="{Binding TextColor}"
                                               FontSize="14"
                                               HorizontalOptions="Start"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Frame>

                </AbsoluteLayout>

            </Grid>
        </Grid>

        <Frame x:Name="BurgerMenuFrame" BackgroundColor="#212143" Padding="0" CornerRadius="0" HasShadow="True" TranslationX="-250" WidthRequest="250" HorizontalOptions="Start" VerticalOptions="Fill" IsVisible="False" ZIndex="2">
            <VerticalStackLayout Spacing="0">
                <Frame BackgroundColor="#212143" Padding="15" CornerRadius="0" Margin="0">
                    <Grid>
                        <Button x:Name="BtnCloseMenu" Text="✕" FontSize="24" Clicked="OnCloseMenuClicked" BackgroundColor="Transparent" TextColor="White" HeightRequest="40" WidthRequest="40" HorizontalOptions="End" VerticalOptions="Center"/>
                    </Grid>
                </Frame>
                <Button x:Name="BtnLista" Text="Lista" BackgroundColor="white" TextColor="#212143" Clicked="OnListaClicked" CornerRadius="0" Margin="0" Padding="20,15" FontSize="16" HorizontalOptions="Fill"/>
                <Button x:Name="BtnMapa" Text="Mapa" BackgroundColor="#212143" TextColor="White" Clicked="OnMapaClicked" CornerRadius="0" Margin="0" Padding="20,15" FontSize="16" HorizontalOptions="Fill"/>
                <Button x:Name="BtnHistorija" Text="Historija Radara" BackgroundColor="#212143" TextColor="White" Clicked="OnHistorijaClicked" CornerRadius="0" Margin="0" Padding="20,15" FontSize="16" HorizontalOptions="Fill"/>
            </VerticalStackLayout>
        </Frame>

        <Grid x:Name="CustomAlertOverlay" IsVisible="False" BackgroundColor="#80000000" ZIndex="10">
            <Frame x:Name="CustomAlertFrame" BackgroundColor="White" CornerRadius="15" Padding="0" HasShadow="True" WidthRequest="300" HeightRequest="200" HorizontalOptions="Center" VerticalOptions="Center">
                <Grid RowDefinitions="60,*,60">
                    <Frame Grid.Row="0" Padding="15" HasShadow="False">
                        <Label x:Name="CustomAlertTitle" Text="Greška" FontSize="20" FontAttributes="Bold" TextColor="Black" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Frame>
                    <Label x:Name="CustomAlertMessage" Grid.Row="1" Text="Došlo je do greške" FontSize="16" TextColor="#2C3E50" HorizontalOptions="Center" VerticalOptions="Center" Padding="20" HorizontalTextAlignment="Center" LineBreakMode="WordWrap"/>
                    <Button x:Name="CustomAlertButton" Grid.Row="2" Text="U REDU" BackgroundColor="#212143" TextColor="White" FontSize="16" FontAttributes="Bold" CornerRadius="10" Margin="20,0,20,15" HeightRequest="45" Clicked="OnCustomAlertButtonClicked"/>
                </Grid>
            </Frame>
        </Grid>
    </Grid>
</ContentPage>
